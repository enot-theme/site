---
import '../styles/global.css';
import { site, base } from '../lib/site';
import { GOATCOUNTER } from '../data/config';

interface Props { title: string; desc: string; page?: string }
const { title, desc, page = '' } = Astro.props;

const canonical = new URL(page, Astro.site).href;
const vision = site.vision;

// Server-set initial custom properties (dark, normal vision) so the
// first paint is correct before the switcher runs.
const dark = vision.enot.dark.normal as Record<string, string>;
const gruv = vision.gruvbox.dark.normal as string[];
let initVars = Object.entries(dark).map(([k, h]) => `--${k}: ${h}`).join('; ');
initVars += '; ' + gruv.map((h, i) => `--gruv${i}: ${h}`).join('; ');

const nav: [string, string][] = [
  ['why/', 'why'], ['numbers/', 'numbers'],
  ['method/', 'method'], ['science/', 'science'],
  ['apps/', 'apps'], ['get/', 'get it'],
];
---
<!doctype html>
<html lang="en" data-mode="dark">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={desc} />
  <link rel="canonical" href={canonical} />
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={desc} />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content={new URL('og.png', Astro.site).href} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt" content="enot colorscheme" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={desc} />
  <meta name="twitter:image" content={new URL('og.png', Astro.site).href} />
  <link rel="icon" type="image/png" href={`${base}favicon.png`} />
  <style set:html={`:root { ${initVars} }`}></style>
  {GOATCOUNTER && (
    <script
      is:inline
      defer
      data-goatcounter={`https://${GOATCOUNTER}.goatcounter.com/count`}
      src="//gc.zgo.at/count.js"></script>
  )}
</head>
<body>
  <header class="top wrap">
    <a class="mark" href={base} aria-label="enot">
      <img class="only-dark" src={`${base}mark-dark.webp`} width="38" height="38" alt="" />
      <img class="only-light" src={`${base}mark-light.webp`} width="38" height="38" alt="" />
    </a>
    <nav>{nav.map(([h, t]) => <a href={`${base}${h}`} aria-current={page === h ? 'page' : undefined}>{t}</a>)}</nav>
  </header>
  <slot />
  <script
    type="application/json"
    id="vision-data"
    is:inline
    set:html={JSON.stringify(vision).replace(/</g, '\\u003c')}></script>
  <script>
    import { initialState, paletteVars, reduceClick } from '../lib/switcher.mjs';

    const dataEl = document.getElementById('vision-data');
    const visionData = JSON.parse(dataEl?.textContent ?? '{}');
    const env = {
      search: location.search,
      saved: (() => { try { return localStorage.getItem('enot-mode'); } catch { return null; } })(),
      prefersLight: window.matchMedia('(prefers-color-scheme: light)').matches,
    };
    let state = initialState(env, visionData);

    function apply() {
      document.documentElement.dataset.mode = state.mode;
      const root = document.documentElement.style;
      for (const [name, value] of paletteVars(visionData, state)) root.setProperty(name, value);
      for (const b of document.querySelectorAll<HTMLElement>('[data-mode]'))
        b.setAttribute('aria-pressed', String(b.dataset.mode === state.mode));
      for (const b of document.querySelectorAll<HTMLElement>('[data-vision]'))
        b.setAttribute('aria-pressed', String(b.dataset.vision === state.vision));
    }

    document.addEventListener('click', (e) => {
      const b = (e.target as HTMLElement | null)?.closest<HTMLElement>(
        '[data-mode],[data-vision],[data-hex]');
      if (!b) return;
      const { state: next, effects, changed } = reduceClick(state, { ...b.dataset });
      state = next;
      for (const fx of effects) {
        if (fx.type === 'persist') {
          try { localStorage.setItem('enot-mode', fx.value); } catch {}
        } else if (fx.type === 'copy' && navigator.clipboard) {
          navigator.clipboard.writeText(fx.value);
          const label = b.lastChild;
          if (label) {
            const old = label.textContent;
            label.textContent = 'copied';
            setTimeout(() => { label.textContent = old; }, 900);
          }
        }
      }
      if (changed) apply();
    });
    apply();
  </script>
</body>
</html>
