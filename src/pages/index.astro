---
import Base from '../layouts/Base.astro';
import Controls from '../components/Controls.astro';
import Editor from '../components/Editor.astro';
import { site, base } from '../lib/site';

const accents = site.accents;
const dark = site.vision.enot.dark.normal;

const title = 'enot - an earthy colorscheme that survives color blindness';
const desc = 'Warm gruvbox-family looks, built in CIELAB, optimized so every pair of colors stays distinguishable under protanopia and deuteranopia. Dark and light. vim, WezTerm, Midnight Commander and ranger.';
---
<Base title={title} desc={desc}>
  <div class="hero wrap">
    <div class="hero-grid">
      <div>
        <h1>enot</h1>
        <div class="tail" aria-hidden="true">{accents.map((r) => <i style={`background:var(--${r})`}></i>)}</div>
        <p class="tagline">An earthy colorscheme that survives color blindness.</p>
        <p class="sub">Warm gruvbox-family looks, built in CIELAB and optimized so
        every pair of colors stays apart under protanopia and deuteranopia -
        the red-green vision deficiencies that affect about 8% of men.
        Dark and light. No hand-picked colors: everything is generated,
        optimized and regression-checked.</p>
        <div class="cta">
          <a class="btn" href={`${base}vim/`}>Get it for vim</a>
          <a class="btn alt" href={`${base}wezterm/`}>WezTerm</a>
          <a class="btn alt" href={`${base}mc/`}>mc</a>
          <a class="btn alt" href={`${base}ranger/`}>ranger</a>
        </div>
      </div>
      <img class="hero-art only-dark" src={`${base}mascot-dark.webp`} width="640" height="640" alt="the enot mascot: an anime raccoon face in the theme colors" />
      <img class="hero-art only-light" src={`${base}mascot-light.webp`} width="640" height="640" alt="the enot mascot: an anime raccoon face in the theme colors" />
    </div>
    <Controls />
    <Editor />
    <div class="strip">
      {accents.map((r) => (
        <button class="sw" data-hex={dark[r]} title={r}><i style={`background:var(--${r})`}></i>{dark[r]}</button>
      ))}
    </div>
    <p class="caption">Swatches and the editor are rendered through the
    selected vision; the hex values are the real colors - click to copy.</p>
    <p class="caption" style="margin-top:14px">Start with
    <a href={`${base}why/`}>why warm themes collapse</a>, check the
    <a href={`${base}numbers/`}>measured guarantees</a> and the
    <a href={`${base}method/`}>method</a> behind them, see the
    <a href={`${base}science/`}>published work</a> it stands on, then
    <a href={`${base}get/`}>get it</a> for your apps.</p>
  </div>

  <footer><div class="wrap">
    <span>enot is the Russian word for raccoon: grey fur, a high-contrast
    mask - neutral backgrounds, distinguishable accents. Read it backwards:
    tone.</span>
    <span>Generated from colors.json. No hand-picked colors.</span>
  </div></footer>
</Base>
