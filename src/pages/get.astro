---
import Base from '../layouts/Base.astro';
import Controls from '../components/Controls.astro';
import { site, base } from '../lib/site';

const accents = site.accents;
const h1 = 'get it';
---
<Base
  title="enot - get it"
  desc="Install the enot colorscheme: vim/neovim, WezTerm, Midnight Commander and ranger - or add a port for another application."
  page="get/">
  <div class="hero wrap">
    <h1 style={`--h1ch:${h1.length}`}>{h1}</h1>
    <div class="tail" aria-hidden="true">{accents.map((r) => <i style={`background:var(--${r})`}></i>)}</div>
    <p class="tagline">Every port is generated from the same spec.</p>
    <p class="sub">Pick an application for the install steps; the full
    list of ports and their depths is in the
    <a href={`${base}apps/`}>coverage matrix</a>.</p>
    <Controls />
  </div>

  <section><div class="wrap">
    <div class="apps">
      <a class="app" href={`${base}vim/`}><b>vim / neovim</b>
      <span>one file, both themes, true-color with a computed 256-color
      fallback, terminal palettes included</span></a>
      <a class="app" href={`${base}wezterm/`}><b>WezTerm</b>
      <span>two TOML schemes, dark and light, with the optimized
      ANSI 16 palette</span></a>
      <a class="app" href={`${base}mc/`}><b>Midnight Commander</b>
      <span>four skins: dark and light, true color plus an xterm-256
      fallback solved on the grid</span></a>
      <a class="app" href={`${base}ranger/`}><b>ranger</b>
      <span>one colorscheme for both themes, driven by the terminal
      ANSI palette</span></a>
      <a class="app ghost" href={`${base}apps/`}><b>add a port</b>
      <span>a port is a manifest the build renders from colors.json;
      the apps page lists them all and how to add one</span></a>
    </div>
  </div></section>

  <footer><div class="wrap">
    <span><a href={base}>&larr; enot</a> - an earthy colorscheme that survives color blindness.</span>
  </div></footer>
</Base>
